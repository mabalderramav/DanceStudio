# Copy this file to .env and adjust values before running docker compose.

API_PORT=8080
SQLSERVER_PORT=1433
ASPNETCORE_ENVIRONMENT=Production
DB_NAME=DanceStudioDb

# SQL Server password must meet complexity requirements.
MSSQL_SA_PASSWORD=YourStrong!Passw0rd

JWT_AUDIENCE=DanceStudio
JWT_ISSUER=DanceStudio
JWT_EXP_MINUTES=60
JWT_SECRET=ReplaceWithALongRandomSecretAtLeast64CharsLongForJwtSigning1234567890

